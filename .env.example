# WordPress backend URL (where pages, posts, and WooCommerce live)
# Default: https://www.rhythmstix.co.uk
# When you move WP to a subdomain, change to e.g. https://cms.rhythmstix.co.uk
VITE_WP_BASE_URL=https://www.rhythmstix.co.uk
WP_BASE_URL=https://www.rhythmstix.co.uk

# Required for WooCommerce product/order integration
WC_CONSUMER_KEY=ck_xxxxx
WC_CONSUMER_SECRET=cs_xxxxx

# Required for user auth and admin
SESSION_SECRET=your-random-secret-string
ADMIN_PASSWORD=your-admin-password

# Required for PostgreSQL database (Neon, Supabase, etc.)
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Optional - Mailchimp email subscription
MAILCHIMP_API_KEY=xxxxx-us1
MAILCHIMP_LIST_ID=xxxxx

# Optional - Vercel auto-provides these
# VERCEL_URL=your-project.vercel.app
# VERCEL_PROJECT_PRODUCTION_URL=your-domain.com
