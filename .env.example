# =============================================================================
# Rhythmstix — environment variables
# =============================================================================
# Copy to `.env` for local dev, or set each one in Vercel → Project → Settings
# → Environment Variables for production.
#
# Tiers:
#   [REQUIRED]    – API will refuse to start, or core features will 500
#   [RECOMMENDED] – feature works but degraded / disabled without it
#   [OPTIONAL]    – has a sensible default
# =============================================================================

# -- [REQUIRED] Database -------------------------------------------------------
# Neon-compatible Postgres connection string. Use the same Neon database for
# Replit dev and Vercel prod, or branch it.
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# -- [REQUIRED] Auth -----------------------------------------------------------
# Random 32+ char string. `openssl rand -base64 32` is fine.
SESSION_SECRET=replace-me-with-32-chars-of-randomness
# Password for the /admin dashboard.
ADMIN_PASSWORD=choose-a-strong-password

# -- [REQUIRED] WooCommerce ----------------------------------------------------
# WooCommerce → Settings → Advanced → REST API. Read permission is enough.
WC_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WC_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -- [RECOMMENDED] Stripe (shop checkout) --------------------------------------
# Get from Stripe Dashboard → Developers → API keys.
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here
# Get from Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret.
# Without this, the /api/webhooks/stripe endpoint REJECTS all events in production.
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -- [OPTIONAL] WooCommerce product webhook ------------------------------------
# Set a long random string here AND in WP Admin → WooCommerce → Webhooks to
# enable instant product sync when stock/prices change. Without it the shop
# still syncs every 30 minutes via the scheduled interval.
WC_WEBHOOK_SECRET=replace-with-random-string

# -- [RECOMMENDED] Vercel Blob (image uploads) ---------------------------------
# Without this, the EditableImage Upload button returns a 503 with a clear
# error. Get it from Vercel → Project → Storage → Blob → "Create" → Connect.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -- [RECOMMENDED] Mailchimp (newsletter signups) ------------------------------
# Both must be set together. Without them newsletter signups silently no-op.
MAILCHIMP_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-us1
MAILCHIMP_LIST_ID=xxxxxxxxxx

# -- [OPTIONAL] WordPress source -----------------------------------------------
# Default: https://www.rhythmstix.co.uk. Override only if you move WP to a
# different domain (e.g. cms.rhythmstix.co.uk).
WP_BASE_URL=https://www.rhythmstix.co.uk
VITE_WP_BASE_URL=https://www.rhythmstix.co.uk

# -- [OPTIONAL] JWT secret -----------------------------------------------------
# Falls back to SESSION_SECRET if unset. Set independently only if you want to
# rotate auth tokens without invalidating other sessions.
# JWT_SECRET=

# -- [OPTIONAL] Logging --------------------------------------------------------
# Default: info. Use "debug" for verbose troubleshooting.
# LOG_LEVEL=info

# -- [OPTIONAL] Frontend URL ---------------------------------------------------
# Auto-detected from Vercel's VERCEL_URL in production. Set manually for
# unusual CORS setups with custom domains.
# FRONTEND_URL=https://rhythmstix.co.uk

# =============================================================================
# Vercel sets these automatically — do NOT define them yourself:
#   VERCEL, VERCEL_URL, VERCEL_PROJECT_PRODUCTION_URL, NODE_ENV,
#   AWS_LAMBDA_FUNCTION_NAME, LAMBDA_TASK_ROOT
# =============================================================================
